# Copy this file to .env and fill in your own values.
# .env is gitignored — never commit real keys.

# --- GitHub ---------------------------------------------------------------
# Personal access token: https://github.com/settings/tokens
# The `public_repo` scope is enough to read public data.
# Add the full `repo` scope if you also want your own private repos counted.
GITHUB_TOKEN=ghp_your_token_here

# --- LLM provider (OpenAI-compatible) -------------------------------------
# Default: Groq — free, no credit card. Get a key at https://console.groq.com/
# Groq keys start with `gsk_`.
LLM_API_KEY=gsk_your_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# --- Alternate free OpenAI-compatible providers ---------------------------
# Any of these work: just swap the base URL, the model, and the key.
# Model names change over time — check the provider's docs for current ones.

# Google Gemini (OpenAI-compatible endpoint) — https://aistudio.google.com/apikey
# LLM_API_KEY=your_gemini_key
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_MODEL=gemini-2.0-flash

# Mistral — https://console.mistral.ai/
# LLM_API_KEY=your_mistral_key
# LLM_BASE_URL=https://api.mistral.ai/v1
# LLM_MODEL=mistral-small-latest

# OpenRouter (has free-tier models) — https://openrouter.ai/keys
# LLM_API_KEY=sk-or-your_key
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Cerebras — https://cloud.cerebras.ai/
# LLM_API_KEY=csk-your_key
# LLM_BASE_URL=https://api.cerebras.ai/v1
# LLM_MODEL=llama-3.3-70b
